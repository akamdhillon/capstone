# =============================================================================
# Clarity+ Environment Configuration
# =============================================================================

# -- Deployment Targets -------------------------------------------------------
# "mac"   -> Running locally on macOS
# "rpi"   -> Running on Raspberry Pi
# "jetson"-> Running on Jetson Nano
BACKEND_TARGET=mac
JETSON_TARGET=mac

# -- Network Addresses --------------------------------------------------------
JETSON_IP=localhost
RPI_IP=localhost

# RPI_IP=192.168.2.1
# JETSON_IP=192.168.2.2

# -- Frontend -----------------------------------------------------------------
VITE_API_URL=http://localhost:8000

# -- Feature Toggles ----------------------------------------------------------
THERMAL_ENABLED=false
DEV_MODE=false

# -- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO

# -- Camera -------------------------------------------------------------------
MAC_CAMERA_INDEX=0

# -- LLM (Voice Assistant) ---------------------------------------------------
# OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_MODEL=llama3.2:1b

# -- Security -----------------------------------------------------------------
ENCRYPTION_KEY=clarity_default_key_change_in_prod!

# -- Data Retention -----------------------------------------------------------
IMAGE_RETENTION_DAYS=30
JANITOR_SCHEDULE_HOUR=2

# -- Docker Runtime (not used in local dev) -----------------------------------
DOCKER_RUNTIME=runc
MODEL_PRECISION=FP32

# -- API Keys (ElevenLabs, PicoVoice) ----------------------------------------
ELEVENLABS_API_KEY="sk_fa863622bac803d5936a6661220e8e7c52f24ed1fa68bd8a"
PICOVOICE_ACCESS_KEY="RCJ96vAOSbv6akIy8P2JF5wbk0evbgGt2BBc/uByGp3au8hK9vfDNg=="
BACKEND_URL="http://localhost:8000/voice/intent"
BACKEND_FACE_URL="http://localhost:8000/api/face/recognize"
