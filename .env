# =============================================================================
# CLARITY+ SMART MIRROR - MAC LOCAL DEVELOPMENT
# =============================================================================
# Use this configuration when running ML services locally on Mac
# Start services: cd jetson && python3 main.py
# Start backend:  cd backend && python -m uvicorn main:app --reload
# Start frontend: cd frontend && npm run dev
# =============================================================================

# -----------------------------------------------------------------------------
# SYSTEM TOGGLES
# -----------------------------------------------------------------------------
THERMAL_ENABLED=false
DEV_MODE=false
LOG_LEVEL=INFO
NODE_ENV=development

# -----------------------------------------------------------------------------
# LOCAL DEVELOPMENT - Point backend to localhost
# -----------------------------------------------------------------------------
RPI_IP=127.0.0.1
JETSON_IP=127.0.0.1

# -----------------------------------------------------------------------------
# JETSON DEVELOPMENT - Point backend to jetson
# -----------------------------------------------------------------------------
# RPI_IP=192.168.2.1
# JETSON_IP=192.168.2.2

# Mac camera index (0=built-in FaceTime, 1+=USB cameras)
MAC_CAMERA_INDEX=0

# -----------------------------------------------------------------------------
# DOCKER RUNTIME (not used in local dev)
# -----------------------------------------------------------------------------
DOCKER_RUNTIME=runc
MODEL_PRECISION=FP32


#API KEYS FOR ELEVEN LABS and PICO Voice
